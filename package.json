{
  "name": "ag-cli",
  "version": "0.3.0",
  "description": "Antigravity-style agent/orchestrator CLI (Node.js + TypeScript)",
  "type": "module",
  "bin": {
    "ag": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/cli.js",
    "dev": "tsx ./src/cli.ts",
    "check": "npm run build && node ./dist/cli.js --help"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "openai": "^4.56.0",
    "playwright": "^1.46.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
